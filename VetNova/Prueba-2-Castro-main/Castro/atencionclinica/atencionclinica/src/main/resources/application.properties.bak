spring.application.name=atencion-clinica-service
server.port=8083

# Conexión a MySQL estandarizada
spring.datasource.url=jdbc:mysql://localhost:3306/db_atencion_clinica?useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
spring.datasource.username=root
spring.datasource.password=
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# Configuración JPA/Hibernate
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect
spring.jpa.hibernate.ddl-auto=update

# Configuración de Swagger UI (Documentación)
springdoc.api-docs.enabled=true
springdoc.swagger-ui.enabled=true
springdoc.swagger-ui.path=/doc/swagger-ui/index.html

# Logs estructurados para Auditoría
logging.level.org.springframework.web=INFO
logging.level.com.vetnova=DEBUG

notificaciones.url=http://localhost:8089/api/v1/notificaciones