# Configuración del servidor y nombre de la aplicación
spring.application.name=auth-service
server.port=8081

# Configuración de base de datos MySQL para Auth_Service
spring.datasource.url=jdbc:mysql://localhost:3306/db_auth_service?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
spring.datasource.username=root
# DEJA ESTA LÍNEA VACÍA SI USAS LARAGON POR DEFECTO
spring.datasource.password=
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# Configuración de JPA/Hibernate
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.hibernate.ddl-auto=update

# Configuración de Swagger UI (Documentación)
springdoc.api-docs.enabled=true
springdoc.swagger-ui.enabled=true
springdoc.swagger-ui.path=/doc/swagger-ui/index.html

# Logs estructurados para Auditoría
logging.level.org.springframework.web=INFO
logging.level.com.vetnova=DEBUG

# Configuración JWT
jwt.secret=vetnova_auth_secret_key_2026_segura_para_desarrollo
jwt.expiration=3600000